# Переменные окружения для деплоя на Amvera Cloud
# Скопируйте эти переменные в панель управления Amvera:
# Проект → Переменные окружения

# PostgreSQL Database (Запуск)
DATABASE_URL=postgresql://user:password@host:port/database

# NextAuth (Запуск)
NEXTAUTH_URL=https://3threep.ru
NEXTAUTH_SECRET=your_32_char_random_string

# Yandex SMTP (Запуск)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=yandex_app_password
SMTP_FROM=noreply@3threep.ru

# Yandex Object Storage
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YANDEX_STORAGE_BUCKET=threep-media
YANDEX_STORAGE_ACCESS_KEY=your_yandex_access_key_id
YANDEX_STORAGE_SECRET_KEY=your_yandex_secret_key
YANDEX_STORAGE_REGION=ru-central1
NEXT_PUBLIC_STORAGE_BASE_URL=https://storage.yandexcloud.net/threep-media

# Администратор
ADMIN_EMAIL=your@email.com

# URL сайта (после привязки домена в Amvera)
# NEXT_PUBLIC_SITE_URL=https://ваш-домен.ru
