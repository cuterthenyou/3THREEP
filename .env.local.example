# PostgreSQL (Amvera)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth
NEXTAUTH_URL=https://3threep.ru
NEXTAUTH_SECRET=your-random-64-char-secret

# Admin access (comma-separated emails)
ADMIN_EMAIL=admin@example.com

# SMTP (Yandex)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=your-app-password
SMTP_FROM=noreply@3threep.ru

# Yandex Object Storage
YANDEX_STORAGE_ACCESS_KEY=your-access-key
YANDEX_STORAGE_SECRET_KEY=your-secret-key
YANDEX_STORAGE_BUCKET=threep-media
YANDEX_STORAGE_REGION=ru-central1
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
NEXT_PUBLIC_STORAGE_BASE_URL=https://storage.yandexcloud.net/threep-media

# Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id
# TELEGRAM_THREAD_ID=optional-thread-id

# Webhook security (optional)
# WEBHOOK_SECRET=random-secret
